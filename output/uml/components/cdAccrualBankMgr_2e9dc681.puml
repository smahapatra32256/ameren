group AreFamilyCareBanksActive
  Caller -> "cdAccrualBankMgr.cls": AreFamilyCareBanksActive()
  activate "cdAccrualBankMgr.cls"
  "cdAccrualBankMgr.cls" -> "cdAccrualBankMgr.cls": Initialize result to False
  alt No error occurs
    "cdAccrualBankMgr.cls" -> "dbEnvironment.cdEnvironment": Create dbEnvironment object
    activate "dbEnvironment.cdEnvironment"
    "dbEnvironment.cdEnvironment" --> "cdAccrualBankMgr.cls": Object created
    deactivate "dbEnvironment.cdEnvironment"
    "cdAccrualBankMgr.cls" -> "dbEnvironment.cdEnvironment": GetSysParmsValue(51, 1)
    activate "dbEnvironment.cdEnvironment"
    "dbEnvironment.cdEnvironment" -> "Database/Config Store": Retrieve system parameter 51, 1
    activate "Database/Config Store"
    "Database/Config Store" --> "dbEnvironment.cdEnvironment": Parameter value
    deactivate "Database/Config Store"
    "dbEnvironment.cdEnvironment" --> "cdAccrualBankMgr.cls": Parameter value
    deactivate "dbEnvironment.cdEnvironment"
    "cdAccrualBankMgr.cls" -> "cdAccrualBankMgr.cls": Convert value to uppercase (UseNewBanks)
    alt If UseNewBanks is "Y" or "TRUE" or "1"
      "cdAccrualBankMgr.cls" -> "cdAccrualBankMgr.cls": Set result to True
    end
    "cdAccrualBankMgr.cls" -> "cdAccrualBankMgr.cls": Release dbEnvironment object
    "cdAccrualBankMgr.cls" --> Caller: Boolean result
  else An error occurs
    "cdAccrualBankMgr.cls" -> "cdAccrualBankMgr.cls": Release dbEnvironment object
    "cdAccrualBankMgr.cls" -> TrsRaiseError: TrsRaiseError(module, function, UseNewBanks, ...)
    activate TrsRaiseError
    TrsRaiseError --> "cdAccrualBankMgr.cls": Error handled
    deactivate TrsRaiseError
    "cdAccrualBankMgr.cls" --> Caller: Function exits due to error
  end
  deactivate "cdAccrualBankMgr.cls"
end
group GetEmployeeBanks
  Caller -> "cdAccrualBankMgr.cls": GetEmployeeBanks(v_aryEmployees, v_datStartDate)
  activate "cdAccrualBankMgr.cls"
  alt v_aryEmployees is an Array
    "cdAccrualBankMgr.cls" -> "cdAccrualBankMgr.cls": BuildInClause for Employee Selection
  else
    "cdAccrualBankMgr.cls" -> "cdAccrualBankMgr.cls": Format single Employee Number
  end
  "cdAccrualBankMgr.cls" -> "cdAccrualBankMgr.cls": Calculate Years and In Clause
  "cdAccrualBankMgr.cls" -> "cdAccrualBankMgr.cls": Call AreFamilyCareBanksActive()
  activate "cdAccrualBankMgr.cls"
  "cdAccrualBankMgr.cls" --> "cdAccrualBankMgr.cls": Boolean result
  deactivate "cdAccrualBankMgr.cls"
  alt If AreFamilyCareBanksActive is True
    "cdAccrualBankMgr.cls" -> BusinessRuleService: AreFamilyCareBanksActive
    activate BusinessRuleService
    BusinessRuleService --> "cdAccrualBankMgr.cls": Result from BusinessRuleService
    deactivate BusinessRuleService
  end
  "cdAccrualBankMgr.cls" --> Caller: ADODB.Recordset (or other result)
  deactivate "cdAccrualBankMgr.cls"
end
